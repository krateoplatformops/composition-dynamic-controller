{
  "uid": "composition-dynamic-controller",
  "title": "Composition Dynamic Controller Overview",
  "tags": [
    "composition-dynamic-controller",
    "unstructured-runtime",
    "otel"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "label": "Prometheus",
        "refresh": 1,
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "current": {}
      },
      {
        "name": "deployment",
        "type": "query",
        "label": "Deployment/Resource",
        "query": "label_values(unstructured_runtime_reconcile_queue_depth, exported_instance)",
        "datasource": "$datasource",
        "refresh": 1,
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "sort": 1,
        "current": {
          "text": "All",
          "value": ".*"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "stat",
      "title": "Controller Saturation",
      "description": "Current queue depth and in-flight reconciliations",
      "datasource": "$datasource",
      "interval": "5m",
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(unstructured_runtime_reconcile_in_flight{exported_instance=~\"$deployment\"}) or vector(0)",
          "legendFormat": "In Flight"
        },
        {
          "refId": "B",
          "expr": "max(unstructured_runtime_reconcile_queue_depth{exported_instance=~\"$deployment\"}) or vector(0)",
          "legendFormat": "Queue Depth"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 101,
      "type": "stat",
      "title": "Success Rate (5m)",
      "description": "Reconciliation success rate",
      "datasource": "$datasource",
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(unstructured_runtime_reconcile_success_total{exported_instance=~\"$deployment\"}[5m])) / (sum(rate(unstructured_runtime_reconcile_success_total{exported_instance=~\"$deployment\"}[5m])) + (sum(rate(unstructured_runtime_reconcile_failure_total{exported_instance=~\"$deployment\"}[5m])) or vector(0)))",
          "legendFormat": "Availability"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 0.95
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 102,
      "type": "stat",
      "title": "Startup Status",
      "description": "Startup success and failure counts",
      "datasource": "$datasource",
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(unstructured_runtime_startup_success_total{exported_instance=~\"$deployment\"}[1h])) or vector(0)",
          "legendFormat": "Success"
        },
        {
          "refId": "B",
          "expr": "sum(increase(unstructured_runtime_startup_failure_total{exported_instance=~\"$deployment\"}[1h])) or vector(0)",
          "legendFormat": "Failure"
        }
      ],
      "options": {
        "colorMode": "value",
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        }
      }
    },
    {
      "id": 200,
      "type": "timeseries",
      "title": "Queue Latency (p95)",
      "description": "Queue wait time (p95) before processing",
      "datasource": "$datasource",
      "interval": "5m",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(unstructured_runtime_reconcile_queue_wait_duration_seconds_bucket{exported_instance=~\"$deployment\"}[5m])))",
          "legendFormat": "Queue Wait"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.5
              },
              {
                "color": "red",
                "value": 1.0
              }
            ]
          }
        }
      }
    },
    {
      "id": 201,
      "type": "timeseries",
      "title": "Queue Oldest Item Age (p95)",
      "description": "Age of oldest item waiting in queue (p95)",
      "datasource": "$datasource",
      "interval": "5m",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(unstructured_runtime_reconcile_queue_oldest_item_age_seconds_bucket{exported_instance=~\"$deployment\"}[5m])))",
          "legendFormat": "Oldest Item Age"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 2.0
              },
              {
                "color": "red",
                "value": 5.0
              }
            ]
          }
        }
      }
    },
    {
      "id": 202,
      "type": "timeseries",
      "title": "Reconcile Duration (p95)",
      "description": "Overall reconciliation duration (p95)",
      "datasource": "$datasource",
      "interval": "5m",
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 0,
        "y": 13
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(unstructured_runtime_reconcile_duration_seconds_bucket{exported_instance=~\"$deployment\"}[5m])))",
          "legendFormat": "Total Duration"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1.0
              },
              {
                "color": "red",
                "value": 5.0
              }
            ]
          }
        }
      }
    },
    {
      "id": 203,
      "type": "timeseries",
      "title": "Queue Work Duration (p95)",
      "description": "Time spent processing items from queue (p95)",
      "datasource": "$datasource",
      "interval": "5m",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 13
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(unstructured_runtime_reconcile_queue_work_duration_seconds_bucket{exported_instance=~\"$deployment\"}[5m])))",
          "legendFormat": "Work Duration"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 204,
      "type": "timeseries",
      "title": "Requeue Reasons (5m)",
      "description": "Requeue count by reason",
      "datasource": "$datasource",
      "interval": "5m",
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 0,
        "y": 21
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(unstructured_runtime_reconcile_queue_requeues_total{exported_instance=~\"$deployment\"}[5m]))",
          "legendFormat": "Total Requeues"
        },
        {
          "refId": "B",
          "expr": "sum(increase(unstructured_runtime_reconcile_requeue_after_total{exported_instance=~\"$deployment\"}[5m]))",
          "legendFormat": "Requeue After"
        },
        {
          "refId": "C",
          "expr": "sum(increase(unstructured_runtime_reconcile_requeue_immediate_total{exported_instance=~\"$deployment\"}[5m]))",
          "legendFormat": "Requeue Immediate"
        },
        {
          "refId": "D",
          "expr": "sum(increase(unstructured_runtime_reconcile_requeue_error_total{exported_instance=~\"$deployment\"}[5m]))",
          "legendFormat": "Requeue Error"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars"
          }
        }
      }
    },
    {
      "id": 205,
      "type": "stat",
      "title": "Failure Counts (5m)",
      "description": "Total reconciliation failures",
      "datasource": "$datasource",
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 12,
        "y": 21
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(unstructured_runtime_reconcile_failure_total{exported_instance=~\"$deployment\"}[5m])) or vector(0)",
          "legendFormat": "Failures"
        }
      ],
      "options": {
        "colorMode": "value",
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        }
      }
    },
    {
      "id": 300,
      "type": "timeseries",
      "title": "External Operation Latency (avg)",
      "description": "Average latency for external operations",
      "datasource": "$datasource",
      "interval": "5m",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(unstructured_runtime_external_observe_duration_seconds_sum{exported_instance=~\"$deployment\"}[5m])) / sum(rate(unstructured_runtime_external_observe_duration_seconds_count{exported_instance=~\"$deployment\"}[5m]))",
          "legendFormat": "Observe"
        },
        {
          "refId": "B",
          "expr": "sum(rate(unstructured_runtime_external_connect_duration_seconds_sum{exported_instance=~\"$deployment\"}[5m])) / sum(rate(unstructured_runtime_external_connect_duration_seconds_count{exported_instance=~\"$deployment\"}[5m]))",
          "legendFormat": "Connect"
        },
        {
          "refId": "C",
          "expr": "sum(rate(unstructured_runtime_external_create_duration_seconds_sum{exported_instance=~\"$deployment\"}[5m])) / sum(rate(unstructured_runtime_external_create_duration_seconds_count{exported_instance=~\"$deployment\"}[5m]))",
          "legendFormat": "Create"
        },
        {
          "refId": "D",
          "expr": "sum(rate(unstructured_runtime_external_update_duration_seconds_sum{exported_instance=~\"$deployment\"}[5m])) / sum(rate(unstructured_runtime_external_update_duration_seconds_count{exported_instance=~\"$deployment\"}[5m]))",
          "legendFormat": "Update"
        },
        {
          "refId": "E",
          "expr": "sum(rate(unstructured_runtime_external_delete_duration_seconds_sum{exported_instance=~\"$deployment\"}[5m])) / sum(rate(unstructured_runtime_external_delete_duration_seconds_count{exported_instance=~\"$deployment\"}[5m]))",
          "legendFormat": "Delete"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 301,
      "type": "stat",
      "title": "External Op Failures (5m)",
      "description": "Total external operation failures",
      "datasource": "$datasource",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 34
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(increase(unstructured_runtime_external_observe_failure_total{exported_instance=~\"$deployment\"}[5m])) or vector(0)) + (sum(increase(unstructured_runtime_external_connect_failure_total{exported_instance=~\"$deployment\"}[5m])) or vector(0))",
          "legendFormat": "Read Failures"
        },
        {
          "refId": "B",
          "expr": "(sum(increase(unstructured_runtime_external_create_failure_total{exported_instance=~\"$deployment\"}[5m])) or vector(0)) + (sum(increase(unstructured_runtime_external_update_failure_total{exported_instance=~\"$deployment\"}[5m])) or vector(0)) + (sum(increase(unstructured_runtime_external_delete_failure_total{exported_instance=~\"$deployment\"}[5m])) or vector(0))",
          "legendFormat": "Write Failures"
        }
      ],
      "options": {
        "colorMode": "value",
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        }
      }
    },
    {
      "id": 302,
      "type": "timeseries",
      "title": "Finalizer Operations Latency",
      "description": "Finalizer add and remove latency (p95)",
      "datasource": "$datasource",
      "interval": "5m",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 34
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(unstructured_runtime_finalizer_add_duration_seconds_bucket{exported_instance=~\"$deployment\"}[5m])))",
          "legendFormat": "Add (p95)"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(unstructured_runtime_finalizer_remove_duration_seconds_bucket{exported_instance=~\"$deployment\"}[5m])))",
          "legendFormat": "Remove (p95)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 303,
      "type": "stat",
      "title": "Finalizer Op Failures (5m)",
      "description": "Finalizer operation failures",
      "datasource": "$datasource",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 42
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(unstructured_runtime_finalizer_add_failure_total{exported_instance=~\"$deployment\"}[5m])) or vector(0)",
          "legendFormat": "Add Failures"
        },
        {
          "refId": "B",
          "expr": "sum(increase(unstructured_runtime_finalizer_remove_failure_total{exported_instance=~\"$deployment\"}[5m])) or vector(0)",
          "legendFormat": "Remove Failures"
        }
      ],
      "options": {
        "colorMode": "value",
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        }
      }
    },
    {
      "id": 304,
      "type": "timeseries",
      "title": "Status Update Latency",
      "description": "Status update duration (p95)",
      "datasource": "$datasource",
      "interval": "5m",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 42
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(unstructured_runtime_status_update_duration_seconds_bucket{exported_instance=~\"$deployment\"}[5m])))",
          "legendFormat": "Status Update (p95)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 305,
      "type": "stat",
      "title": "Status Update Failures (5m)",
      "description": "Status update operation failures",
      "datasource": "$datasource",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 50
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(unstructured_runtime_status_update_failure_total{exported_instance=~\"$deployment\"}[5m])) or vector(0)",
          "legendFormat": "Status Update Failures"
        }
      ],
      "options": {
        "colorMode": "value",
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        }
      }
    },
    {
      "id": 306,
      "type": "timeseries",
      "title": "Get Operation Latency",
      "description": "Resource get/fetch operation latency (p95)",
      "datasource": "$datasource",
      "interval": "5m",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 50
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(unstructured_runtime_reconcile_get_duration_seconds_bucket{exported_instance=~\"$deployment\"}[5m])))",
          "legendFormat": "Get Duration (p95)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      }
    }
  ]
}